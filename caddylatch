SUBPROCESS_TIMEOUT = 30  # seconds


def wg_is_up(interface: str) -> bool:
    r = subprocess.run(["ip", "link", "show", interface], capture_output=True, text=True, timeout=10)
    return "UP" in r.stdout if r.returncode == 0 else False


def wg_up(interface: str) -> bool:
    logging.info(f"Starting WireGuard interface {interface}")
    try:
        r = subprocess.run(["systemctl", "start", f"wg-quick@{interface}"],
                           capture_output=True, text=True, timeout=SUBPROCESS_TIMEOUT)
        if r.returncode != 0:
            logging.error(f"Failed to start WireGuard: {r.stderr}")
            return False
        subprocess.run(["systemctl", "enable", f"wg-quick@{interface}"],
                       capture_output=True, text=True, timeout=10)
        return True
    except subprocess.TimeoutExpired:
        logging.error(f"WireGuard start timed out after {SUBPROCESS_TIMEOUT}s")
        return False


def wg_down(interface: str) -> bool:
    logging.info(f"Stopping WireGuard interface {interface}")
    try:
        r = subprocess.run(["systemctl", "stop", f"wg-quick@{interface}"],
                           capture_output=True, text=True, timeout=SUBPROCESS_TIMEOUT)
        if r.returncode != 0:
            logging.error(f"Failed to stop WireGuard: {r.stderr}")
            return False
        subprocess.run(["systemctl", "disable", f"wg-quick@{interface}"],
                       capture_output=True, text=True, timeout=10)
        return True
    except subprocess.TimeoutExpired:
        logging.error(f"WireGuard stop timed out after {SUBPROCESS_TIMEOUT}s")
        return False


def wg_stats(interface: str) -> dict:
    """Parse wg show output for transfer and handshake stats."""
    stats = {"transfer_rx": None, "transfer_tx": None, "latest_handshake": None}
    try:
        r = subprocess.run(["wg", "show", interface], capture_output=True, text=True)
        if r.returncode != 0:
            return stats
        for line in r.stdout.splitlines():
            line = line.strip()
            if line.startswith("transfer:"):
                parts = line.split(",")
                for part in parts:
                    part = part.strip()
                    if "received" in part:
                        stats["transfer_rx"] = part.split("transfer:")[-1].split("received")[0].strip().lstrip()
                    elif "sent" in part:
                        stats["transfer_tx"] = part.split("sent")[0].strip()
                # re-parse more carefully
                raw = line.replace("transfer:", "").strip()
                pieces = raw.split(",")
                if len(pieces) == 2:
                    stats["transfer_rx"] = pieces[0].strip().replace(" received", "")
                    stats["transfer_tx"] = pieces[1].strip().replace(" sent", "")
            elif line.startswith("latest handshake:"):
                stats["latest_handshake"] = line.replace("latest handshake:", "").strip()
    except Exception as e:
        logging.debug(f"wg_stats error: {e}")
    return stats


# ---------------------------------------------------------------------------
# Caddy filter management
# ---------------------------------------------------------------------------

FILTER_HEADER = """\
# Managed by CaddyLatch — do not edit manually.
# This file is regenerated on every state change.
# Manual edits will be overwritten.
#
# To modify allowed countries or IPs, use the CaddyLatch API.
"""


def write_filter_locked(cfg: dict) -> None:
    content = FILTER_HEADER + """
# STATE: LOCKED — all traffic blocked
(geo_filter) {
    @geo_blocked {
        not remote_ip %(wg_peer_ip)s/32
    }
    handle @geo_blocked {
        abort
    }
}
""" % {"wg_peer_ip": cfg["wg_peer_ip"]}
    Path(cfg["caddy_filter_file"]).write_text(content)
    logging.info("Wrote locked filter (all traffic blocked)")


def write_filter_open(cfg: dict, countries: list[str], ips: list[str],
                      all_countries: bool = False) -> None:
    wg = cfg["wg_peer_ip"]
    db = cfg["geoip_db_path"]

    has_geo = not all_countries and len(countries) > 0
    has_ips = len(ips) > 0

    if all_countries and not has_ips:
        # All countries, any IP — only block non-WG traffic that somehow bypasses
        # Actually: allow everything except enforce WG peer exemption
        content = FILTER_HEADER + f"""
# STATE: OPEN — all countries, any IP
(geo_filter) {{
    # No filtering — all traffic allowed
}}
"""
    elif all_countries and has_ips:
        # All countries, specific IPs
        ip_list = " ".join(ips)
        content = FILTER_HEADER + f"""
# STATE: OPEN — all countries, IP-filtered
(geo_filter) {{
    @ip_blocked {{
        not remote_ip {ip_list} {wg}/32
    }}
    handle @ip_blocked {{
        abort
    }}
}}
"""
    elif has_geo and has_ips:
        # Specific countries AND specific IPs
        country_list = " ".join(c.upper() for c in countries)
        ip_list = " ".join(ips)
        content = FILTER_HEADER + f"""
# STATE: OPEN — geo + IP filtered
# Required: matching country AND matching IP
(geo_filter) {{
    @geo_blocked {{
        not maxmind_geolocation {{
            db_path {db}
            allow_countries {country_list}
        }}
        not remote_ip {wg}/32
    }}
    handle @geo_blocked {{
        abort
    }}

    @ip_blocked {{
        not remote_ip {ip_list} {wg}/32
    }}
    handle @ip_blocked {{
        abort
    }}
}}
"""
    elif has_geo:
        # Specific countries, any IP
        country_list = " ".join(c.upper() for c in countries)
        content = FILTER_HEADER + f"""
# STATE: OPEN — geo-filtered, any IP
(geo_filter) {{
    @geo_blocked {{
        not maxmind_geolocation {{
            db_path {db}
            allow_countries {country_list}
        }}
        not remote_ip {wg}/32
    }}
    handle @geo_blocked {{
        abort
    }}
}}
"""
    else:
        # No countries, no IPs — shouldn't happen, lock down
        write_filter_locked(cfg)
        return

    Path(cfg["caddy_filter_file"]).write_text(content)
    logging.info(f"Wrote open filter — all_countries={all_countries}, "
                 f"countries={countries}, ips={ips}")


def reload_caddy(cmd: str) -> bool:
    logging.info("Reloading Caddy")
    try:
        r = subprocess.run(cmd.split(), capture_output=True, text=True, timeout=SUBPROCESS_TIMEOUT)
        if r.returncode != 0:
            logging.error(f"Caddy reload failed: {r.stderr}")
            return False
        return True
    except subprocess.TimeoutExpired:
        logging.error(f"Caddy reload timed out after {SUBPROCESS_TIMEOUT}s")
        return False


# ---------------------------------------------------------------------------
# Notifications
