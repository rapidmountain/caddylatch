def _ntfy_worker(cfg: dict, title: str, message: str, priority: str) -> None:
    """Background worker — fire and forget, single attempt."""
    url = f"{cfg['ntfy_url']}/{cfg['ntfy_topic']}"
    headers = {"Priority": priority, "Tags": "lock"}
    headers["Title"] = title.encode("utf-8")

    ntfy_token = cfg.get("ntfy_token", "")
    ntfy_user = cfg.get("ntfy_user", "")
    ntfy_pass = cfg.get("ntfy_pass", "")

    if ntfy_token:
        headers["Authorization"] = f"Bearer {ntfy_token}"
    elif ntfy_user and ntfy_pass:
        cred = base64.b64encode(f"{ntfy_user}:{ntfy_pass}".encode()).decode()
        headers["Authorization"] = f"Basic {cred}"

    try:
        req = urllib.request.Request(url, data=message.encode("utf-8"), headers=headers)
        urllib.request.urlopen(req, timeout=5)
        logging.info(f"ntfy sent: {title}")
    except Exception as e:
        logging.error(f"ntfy failed: {e}")


def send_ntfy(cfg: dict, title: str, message: str, priority: int | None = None) -> None:
    """Send ntfy notification asynchronously (non-blocking)."""
    if not cfg.get("ntfy_url") or not cfg.get("ntfy_topic"):
        return
    prio = str(priority or cfg["ntfy_priority"])
    t = threading.Thread(target=_ntfy_worker, args=(cfg, title, message, prio), daemon=True)
    t.start()


def ping_healthchecks(cfg: dict, status: str = "") -> None:
    url = cfg.get("healthchecks_url")
    if not url:
        return
    ping_url = f"{url}/{status}" if status else url
    try:
        urllib.request.urlopen(ping_url, timeout=10)
    except Exception as e:
        logging.error(f"Healthchecks ping failed: {e}")


# ---------------------------------------------------------------------------
# Latch controller
# ---------------------------------------------------------------------------

class LatchController:
    """Coordinates WireGuard, Caddy filters, timers, and notifications."""

    def __init__(self, cfg: dict, state: LatchState, ip_lists: IPListStore):
        self.cfg = cfg
        self.state = state
        self.ip_lists = ip_lists
        self._timer: threading.Timer | None = None
        self._reminder_stop = threading.Event()
        self._reminder_thread: threading.Thread | None = None
        self._lock = threading.Lock()
        self._start_time = now_utc()
        self._reconcile_on_startup()

    @staticmethod
    def _wait_for_caddy(max_wait: int = 30) -> bool:
        """Wait until Caddy is fully active (not reloading/starting)."""
        for i in range(max_wait):
            try:
                r = subprocess.run(
                    ["systemctl", "is-active", "caddy"],
                    capture_output=True, text=True, timeout=5,
                )
                if r.stdout.strip() == "active":
                    if i > 0:
                        logging.info(f"Caddy became active after {i}s")
                    return True
            except subprocess.TimeoutExpired:
                pass
            time.sleep(1)
        logging.error(f"Caddy not active after {max_wait}s")
        return False

    def _reconcile_on_startup(self) -> None:
        current = self.state.get()
        wg_iface = self.cfg["wg_interface"]

        # Wait for Caddy to be fully ready before any reload
        self._wait_for_caddy()

        if current["enabled"]:
            if current["expires"]:
                expires = datetime.fromisoformat(current["expires"])
                if now_utc() >= expires:
                    logging.warning("Latch was open but timer expired while agent was offline — locking")
                    self._do_disable("backstop (expired while agent was offline)")
                    return

            logging.info("Reconciling: latch should be open, ensuring system state matches")
            if not wg_is_up(wg_iface):
                wg_up(wg_iface)

            all_ips = self._resolve_ips(
                current.get("allowed_ips", []),
                current.get("allowed_ip_lists", []),
            )
            write_filter_open(
                self.cfg,
                current.get("allowed_countries", []),
                all_ips,
                current.get("all_countries", False),
            )
            reload_caddy(self.cfg["caddy_reload_cmd"])
            if current["expires"]:
                self._start_timer()
            self._start_reminder()

            send_ntfy(
                self.cfg,
                "CaddyLatch — agent restarted",
                f"Latch is open. Expires: {format_display_time(current['expires'], self.cfg['display_timezone']) if current['expires'] else 'never'}",
            )
        else:
            logging.info("Reconciling: latch should be locked, ensuring system state matches")
            if wg_is_up(wg_iface):
                logging.warning("WireGuard is up but latch is locked — stopping")
                wg_down(wg_iface)
            write_filter_locked(self.cfg)
            reload_caddy(self.cfg["caddy_reload_cmd"])

    def _resolve_ips(self, direct_ips: list[str], list_names: list[str]) -> list[str]:
        """Combine direct IPs with resolved IP list entries, deduplicated."""
        all_ips = list(direct_ips)
        all_ips.extend(self.ip_lists.resolve(list_names))
        return list(dict.fromkeys(all_ips))  # dedupe, preserve order

    def enable(self, allowed_ips: list[str], allowed_ip_lists: list[str],
               allowed_countries: list[str], all_countries: bool = False,
               duration_minutes: int | None = None) -> dict:
        """Open the latch."""
        with self._lock:
            wg_iface = self.cfg["wg_interface"]
            default_dur = int(self.cfg["default_duration_minutes"])

            if duration_minutes is None:
                duration = default_dur
            else:
                duration = duration_minutes

            now = now_utc()
            expires_iso = None
            if duration > 0:
                expires = datetime.fromtimestamp(now.timestamp() + duration * 60, tz=timezone.utc)
                expires_iso = expires.isoformat()

            # Resolve all IPs
            all_ips = self._resolve_ips(allowed_ips, allowed_ip_lists)

            # Validate: need at least geo or IP restriction (unless all_countries)
            if not all_countries and not allowed_countries and not all_ips:
                return {"error": "at least one of countries, IPs, or all_countries required"}

            # 1. Write filter
            write_filter_open(self.cfg, allowed_countries, all_ips, all_countries)

            # 2. Reload Caddy
            if not reload_caddy(self.cfg["caddy_reload_cmd"]):
                # Write locked filter to disk — Caddy will pick it up when it
                # recovers, so do NOT send another reload signal here; piling
                # on SIGHUPs is what causes Caddy to get stuck.
                write_filter_locked(self.cfg)
                send_ntfy(self.cfg, "⚠️ CaddyLatch — FAILED to open",
                          "Caddy reload failed, filters rolled back",
                          int(self.cfg["ntfy_alert_priority"]))
                return {"error": "Caddy reload failed"}

            # 3. Start WireGuard
            if not wg_up(wg_iface):
                write_filter_locked(self.cfg)
                reload_caddy(self.cfg["caddy_reload_cmd"])
                send_ntfy(self.cfg, "⚠️ CaddyLatch — FAILED to open",
                          "WireGuard failed to start, filters rolled back",
                          int(self.cfg["ntfy_alert_priority"]))
                return {"error": "WireGuard failed to start"}

            # 4. Persist state
            new_state = self.state.update({
                "enabled": True,
                "allowed_ips": allowed_ips,
                "allowed_ip_lists": allowed_ip_lists,
                "allowed_countries": allowed_countries,
                "all_countries": all_countries,
                "last_countries": allowed_countries,
                "last_all_countries": all_countries,
                "expires": expires_iso,
                "enabled_at": now.isoformat(),
                "last_opened": now.isoformat(),
                "disabled_reason": None,
            })

            # 5. Timer + reminder
            if duration > 0:
                self._start_timer()
            self._start_reminder()

            # 6. Notify
            tz = self.cfg["display_timezone"]
            exp_display = format_display_time(expires_iso, tz) if expires_iso else "never (manual close only)"
            dur_display = f"{duration} min" if duration > 0 else "unlimited"
            geo_display = "all" if all_countries else (", ".join(allowed_countries) or "none")
            ip_display = ", ".join(all_ips) or "any"

            send_ntfy(self.cfg, "🔓 CaddyLatch OPEN",
                      f"Countries: {geo_display}\nIPs: {ip_display}\n"
                      f"Expires: {exp_display}\nDuration: {dur_display}")
            ping_healthchecks(self.cfg)

            logging.info(f"Latch opened — countries={allowed_countries}, "
                         f"all_countries={all_countries}, ips={all_ips}, expires={expires_iso}")
            return new_state

    def disable(self, reason: str = "manual") -> dict:
        with self._lock:
            return self._do_disable(reason)

    def _do_disable(self, reason: str) -> dict:
        wg_iface = self.cfg["wg_interface"]
        self._cancel_timer()
        self._cancel_reminder()

        # 1. Notify (async, while WG might still be up)
        normal_reasons = ("manual", "timer expired")
        is_backstop = reason not in normal_reasons
        priority = int(self.cfg["ntfy_alert_priority"]) if is_backstop else int(self.cfg["ntfy_priority"])
        title = "🔒 CaddyLatch LOCKED (backstop)" if is_backstop else "🔒 CaddyLatch LOCKED"
        send_ntfy(self.cfg, title, f"Reason: {reason}", priority)

        # 2. Stop WireGuard
        wg_down(wg_iface)

        # 3. Lock filter
        write_filter_locked(self.cfg)

        # 4. Reload Caddy
        reload_caddy(self.cfg["caddy_reload_cmd"])

        # 5. Persist state
        now = now_utc()
        new_state = self.state.update({
            "enabled": False,
            "allowed_ips": [],
            "allowed_ip_lists": [],
            "allowed_countries": [],
            "all_countries": False,
            "expires": None,
            "enabled_at": None,
            "disabled_reason": reason,
            "last_closed": now.isoformat(),
        })
        ping_healthchecks(self.cfg)
        logging.info(f"Latch locked — reason={reason}")
        return new_state

    def update_filters(self, allowed_ips: list[str], allowed_ip_lists: list[str],
                       allowed_countries: list[str], all_countries: bool = False) -> dict:
        with self._lock:
            if not self.state.enabled:
                return {"error": "latch is not open"}

            all_ips = self._resolve_ips(allowed_ips, allowed_ip_lists)
            if not all_countries and not allowed_countries and not all_ips:
                return {"error": "at least one of countries, IPs, or all_countries required"}

            write_filter_open(self.cfg, allowed_countries, all_ips, all_countries)
            if not reload_caddy(self.cfg["caddy_reload_cmd"]):
                return {"error": "Caddy reload failed"}

            new_state = self.state.update({
                "allowed_ips": allowed_ips,
                "allowed_ip_lists": allowed_ip_lists,
                "allowed_countries": allowed_countries,
                "all_countries": all_countries,
                "last_countries": allowed_countries,
                "last_all_countries": all_countries,
            })
            send_ntfy(self.cfg, "🔓 CaddyLatch filters updated",
                      f"Countries: {'all' if all_countries else ', '.join(allowed_countries) or 'none'}\n"
                      f"IPs: {', '.join(all_ips) or 'any'}")
            logging.info(f"Filters updated — countries={allowed_countries}, ips={all_ips}")
            return new_state

    def extend(self, additional_minutes: int) -> dict:
        with self._lock:
            state = self.state.get()
            if not state["enabled"]:
                return {"error": "latch is not open"}
            if not state["expires"]:
                return {"error": "latch has no timer to extend"}

            current_exp = datetime.fromisoformat(state["expires"])

            new_exp = datetime.fromtimestamp(
                current_exp.timestamp() + additional_minutes * 60, tz=timezone.utc)

            new_state = self.state.update({"expires": new_exp.isoformat()})
            self._start_timer()

            tz = self.cfg["display_timezone"]
            send_ntfy(self.cfg, "⏱️ CaddyLatch extended",
                      f"New expiry: {format_display_time(new_exp.isoformat(), tz)}\n"
                      f"Added: {additional_minutes} min")
            logging.info(f"Timer extended by {additional_minutes} min to {new_exp.isoformat()}")
            return new_state

    def set_timer(self, duration_minutes: int) -> dict:
        """Set a timer on an already-open session that has no timer."""
        with self._lock:
            state = self.state.get()
            if not state["enabled"]:
                return {"error": "latch is not open"}
            if state["expires"]:
                return {"error": "latch already has a timer"}
            now = now_utc()
            expires = datetime.fromtimestamp(
                now.timestamp() + duration_minutes * 60, tz=timezone.utc)
            new_state = self.state.update({"expires": expires.isoformat()})
            self._start_timer()
            tz = self.cfg["display_timezone"]
            send_ntfy(self.cfg, "⏱️ CaddyLatch timer set",
                      f"Expires: {format_display_time(expires.isoformat(), tz)}\n"
                      f"Duration: {duration_minutes} min")
            logging.info(f"Timer set to {duration_minutes} min, expires {expires.isoformat()}")
            return new_state

    def get_stats(self) -> dict:
        """Return operational stats for the web UI."""
        state = self.state.get()
        wg_iface = self.cfg["wg_interface"]
        agent_uptime = (now_utc() - self._start_time).total_seconds()

        stats = {
            "last_opened": state.get("last_opened"),
            "last_closed": state.get("last_closed"),
            "agent_uptime_seconds": int(agent_uptime),
        }

        if state["enabled"] and state.get("enabled_at"):
            session_start = datetime.fromisoformat(state["enabled_at"])
            stats["session_uptime_seconds"] = int((now_utc() - session_start).total_seconds())

        if wg_is_up(wg_iface):
            wg = wg_stats(wg_iface)
            stats["wg_transfer_rx"] = wg.get("transfer_rx")
            stats["wg_transfer_tx"] = wg.get("transfer_tx")
            stats["wg_latest_handshake"] = wg.get("latest_handshake")

        return stats

    # --- Timer ---

    def _start_timer(self) -> None:
        self._cancel_timer()
        expires = self.state.expires
        if not expires:
            return
        remaining = (expires - now_utc()).total_seconds()
        if remaining <= 0:
            self._do_disable("timer expired")
            return
        logging.info(f"Timer set: {remaining:.0f}s remaining")
        self._timer = threading.Timer(remaining, self._on_timer_expire)
        self._timer.daemon = True
        self._timer.start()

    def _cancel_timer(self) -> None:
        if self._timer:
            self._timer.cancel()
            self._timer = None

    def _on_timer_expire(self) -> None:
        logging.warning("Timer expired — locking latch")
        with self._lock:
            if self.state.enabled:
                self._do_disable("timer expired")

    # --- Reminder ---

    def _start_reminder(self) -> None:
        self._cancel_reminder()
        interval = int(self.cfg["reminder_interval_minutes"]) * 60
        if interval <= 0:
            return
        self._reminder_stop = threading.Event()
        stop = self._reminder_stop

        def remind():
            while not stop.wait(interval):
                state = self.state.get()
                if not state["enabled"]:
                    break
                remaining = ""
                expires_display = "never"
                if state.get("expires"):
                    exp = datetime.fromisoformat(state["expires"])
                    mins_left = (exp - now_utc()).total_seconds() / 60
                    remaining = f"\nTime remaining: {int(mins_left)} min"
                    expires_display = format_display_time(state["expires"], self.cfg["display_timezone"])
                send_ntfy(self.cfg, "ℹ️ CaddyLatch still open",
                          f"Expires: {expires_display}{remaining}")
                logging.info("Sent 'still open' reminder")

        self._reminder_thread = threading.Thread(target=remind, daemon=True)
        self._reminder_thread.start()

    def _cancel_reminder(self) -> None:
        if self._reminder_stop:
            self._reminder_stop.set()
        self._reminder_thread = None


# ---------------------------------------------------------------------------
# HTTP API
# ---------------------------------------------------------------------------

class APIHandler(BaseHTTPRequestHandler):
    controller: LatchController = None
    cfg: dict = None
    ip_lists: IPListStore = None

    def _json(self, status: int, data: dict) -> None:
        body = json.dumps(data, indent=2).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()
        self.wfile.write(body)

    def _body(self) -> dict | None:
        length = int(self.headers.get("Content-Length", 0))
        if length == 0:
            return None
        try:
            return json.loads(self.rfile.read(length))
        except (json.JSONDecodeError, ValueError):
            return None

    def do_OPTIONS(self) -> None:
        self.send_response(204)
        self.send_header("Access-Control-Allow-Origin", "*")
        self.send_header("Access-Control-Allow-Methods", "GET, POST, PUT, DELETE, OPTIONS")
        self.send_header("Access-Control-Allow-Headers", "Content-Type")
        self.end_headers()

    def do_GET(self) -> None:
        if self.path == "/" or self.path == "/index.html":
            self._serve_web_ui()

        elif self.path == "/health":
            self._json(200, {"status": "ok", "version": __version__})

        elif self.path == "/status":
            state = self.controller.state.get()
            state["wg_up"] = wg_is_up(self.cfg["wg_interface"])
            state["version"] = __version__
            self._json(200, state)

        elif self.path == "/stats":
            self._json(200, self.controller.get_stats())

        elif self.path == "/ip-lists":
            self._json(200, self.ip_lists.get_all())

        else:
            self._json(404, {"error": "not found"})

    def _serve_web_ui(self) -> None:
        """Serve the web UI HTML file."""
        # Look for index.html relative to the executable's real path
        exe = Path(__file__).resolve().parent
        candidates = [
            exe / "web" / "index.html",
            Path("/opt/caddylatch/web/index.html"),
        ]
        for path in candidates:
            if path.exists():
                try:
                    content = path.read_bytes()
                    self.send_response(200)
                    self.send_header("Content-Type", "text/html; charset=utf-8")
                    self.send_header("Content-Length", str(len(content)))
                    self.end_headers()
                    self.wfile.write(content)
                    return
                except Exception as e:
                    logging.error(f"Failed to serve web UI: {e}")
                    break
        self._json(404, {"error": "web UI not found"})

    def do_POST(self) -> None:
        if self.path == "/enable":
            body = self._body()
            if not body:
                self._json(400, {"error": "missing request body"})
                return
            result = self.controller.enable(
                allowed_ips=body.get("allowed_ips", []),
                allowed_ip_lists=body.get("allowed_ip_lists", []),
                allowed_countries=body.get("allowed_countries", []),
                all_countries=body.get("all_countries", False),
                duration_minutes=body.get("duration_minutes"),
            )
            self._json(500 if "error" in result else 200, result)

        elif self.path == "/disable":
            result = self.controller.disable(reason="manual")
            self._json(200, result)

        elif self.path == "/extend":
            body = self._body()
            if not body:
                self._json(400, {"error": "missing request body"})
                return
            mins = body.get("additional_minutes")
            if not mins or mins <= 0:
                self._json(400, {"error": "positive additional_minutes required"})
                return
            result = self.controller.extend(mins)
            self._json(400 if "error" in result else 200, result)

        elif self.path == "/set-timer":
            body = self._body()
            if not body:
                self._json(400, {"error": "missing request body"})
                return
            mins = body.get("duration_minutes")
            if not mins or mins <= 0:
                self._json(400, {"error": "positive duration_minutes required"})
                return
            result = self.controller.set_timer(mins)
            self._json(400 if "error" in result else 200, result)

        elif self.path == "/update-filters":
            body = self._body()
            if not body:
                self._json(400, {"error": "missing request body"})
                return
            result = self.controller.update_filters(
                allowed_ips=body.get("allowed_ips", []),
                allowed_ip_lists=body.get("allowed_ip_lists", []),
                allowed_countries=body.get("allowed_countries", []),
                all_countries=body.get("all_countries", False),
            )
            self._json(400 if "error" in result else 200, result)

        else:
            self._json(404, {"error": "not found"})

    def do_PUT(self) -> None:
        if self.path.startswith("/ip-lists/"):
            name = urllib.parse.unquote(self.path[len("/ip-lists/"):])
            if not name:
                self._json(400, {"error": "list name required"})
                return
            body = self._body()
            if not body or "ips" not in body:
                self._json(400, {"error": "ips array required"})
                return
            # Create or update
            existing = self.ip_lists.get(name)
            if existing is not None:
                result = self.ip_lists.update(name, body["ips"])
            else:
                result = self.ip_lists.create(name, body["ips"])
            self._json(200, result)
        else:
            self._json(404, {"error": "not found"})

    def do_DELETE(self) -> None:
        if self.path.startswith("/ip-lists/"):
            name = urllib.parse.unquote(self.path[len("/ip-lists/"):])
            if not name:
                self._json(400, {"error": "list name required"})
                return
            result = self.ip_lists.delete(name)
            if result is None:
                self._json(404, {"error": f"list '{name}' not found"})
            else:
                self._json(200, result)
        else:
            self._json(404, {"error": "not found"})

    def log_message(self, format, *args) -> None:
        logging.debug(f"HTTP: {args[0]}")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------

def main() -> None:
    cfg = load_config()
    setup_logging(cfg)

    listen_host = cfg["listen_host"]
    if listen_host == "CHANGE_ME":
        logging.error("listen_host is not configured. Edit %s.", CONFIG_PATH)
        sys.exit(1)

    logging.info(f"CaddyLatch v{__version__} starting")

    state = LatchState(cfg["state_file"])
    ip_lists = IPListStore(cfg["ip_lists_file"])
    controller = LatchController(cfg, state, ip_lists)

    APIHandler.controller = controller
    APIHandler.cfg = cfg
    APIHandler.ip_lists = ip_lists

    port = int(cfg["listen_port"])
    server = HTTPServer((listen_host, port), APIHandler)
    logging.info(f"API listening on {listen_host}:{port}")

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        logging.info("Shutting down")
        server.shutdown()


if __name__ == "__main__":
    main()
