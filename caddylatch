class IPListStore:
    """Manages named IP address lists with persistence."""

    def __init__(self, filepath: str):
        self._file = Path(filepath)
        self._lock = threading.Lock()
        self._lists = self._load()

    def _load(self) -> dict:
        try:
            with open(self._file) as f:
                return json.load(f)
        except (FileNotFoundError, json.JSONDecodeError):
            return {}

    def _save(self) -> None:
        self._file.parent.mkdir(parents=True, exist_ok=True)
        tmp = self._file.with_suffix(".tmp")
        with open(tmp, "w") as f:
            json.dump(self._lists, f, indent=2)
        tmp.rename(self._file)

    def get_all(self) -> dict:
        with self._lock:
            return dict(self._lists)

    def get(self, name: str) -> list[str] | None:
        with self._lock:
            return self._lists.get(name)

    def create(self, name: str, ips: list[str]) -> dict:
        with self._lock:
            self._lists[name] = ips
            self._save()
            return dict(self._lists)

    def update(self, name: str, ips: list[str]) -> dict | None:
        with self._lock:
            if name not in self._lists:
                return None
            self._lists[name] = ips
            self._save()
            return dict(self._lists)

    def delete(self, name: str) -> dict | None:
        with self._lock:
            if name not in self._lists:
                return None
            del self._lists[name]
            self._save()
            return dict(self._lists)

    def resolve(self, names: list[str]) -> list[str]:
        """Resolve list names to flat list of IPs."""
        with self._lock:
            ips = []
            for name in names:
                if name in self._lists:
                    ips.extend(self._lists[name])
            return ips


