DEFAULT_STATE = {
    "enabled": False,
    "allowed_ips": [],
    "allowed_ip_lists": [],
    "allowed_countries": [],
    "all_countries": False,
    "expires": None,
    "updated_at": None,
    "enabled_at": None,
    "disabled_reason": None,
    "last_opened": None,
    "last_closed": None,
    # Last-used country selection, preserved across a lock so the web UI can
    # restore the previous configuration instead of a hardcoded default.
    "last_countries": [],
    "last_all_countries": False,
}


class LatchState:
    """Thread-safe state manager with persistence."""

    def __init__(self, state_file: str):
        self._file = Path(state_file)
        self._lock = threading.Lock()
        self._state = self._load()

    def _load(self) -> dict:
        try:
            with open(self._file) as f:
                stored = json.load(f)
                merged = dict(DEFAULT_STATE)
                merged.update(stored)
                return merged
        except (FileNotFoundError, json.JSONDecodeError):
            return dict(DEFAULT_STATE)

    def _save(self) -> None:
        self._file.parent.mkdir(parents=True, exist_ok=True)
        tmp = self._file.with_suffix(".tmp")
        with open(tmp, "w") as f:
            json.dump(self._state, f, indent=2)
        tmp.rename(self._file)

    def get(self) -> dict:
        with self._lock:
            return dict(self._state)

    def update(self, new: dict) -> dict:
        with self._lock:
            self._state.update(new)
            self._state["updated_at"] = now_utc().isoformat()
            self._save()
            return dict(self._state)

    @property
    def enabled(self) -> bool:
        with self._lock:
            return self._state.get("enabled", False)

    @property
    def expires(self) -> datetime | None:
        with self._lock:
            exp = self._state.get("expires")
            return datetime.fromisoformat(exp) if exp else None


